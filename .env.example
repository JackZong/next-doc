# ================================
# NextDoc 配置
# ================================

# 网站信息
NEXT_PUBLIC_SITE_NAME=NextDoc
NEXT_PUBLIC_SITE_DESCRIPTION=团队文档管理系统

# ================================
# 数据库配置
# ================================

# 数据库类型: sqlite | mysql | postgres
# 注意：切换数据库类型后，需要运行相应数据库的迁移或推送脚本
DB_TYPE=sqlite

# SQLite 配置 (默认)
SQLITE_PATH=./data/nextdoc.db

# MySQL 配置 (当 DB_TYPE=mysql 时启用)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=next-doc

# PostgreSQL 配置 (当 DB_TYPE=postgres 时启用)
# POSTGRES_URL=postgresql://user:password@localhost:5432/next-doc

# ================================
# 认证配置
# ================================

# JWT 密钥（生产环境请使用强密钥）
JWT_SECRET=your-super-secret-jwt-key-change-in-production
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ================================
# 第三方登录配置 (OAuth 2.0)
# ================================
# 配置完成后需要重启服务方可生效。

# GitHub 登录:
# 1. 访问 https://github.com/settings/developers 并新建 OAuth App
# 2. Homepage URL: http://localhost:3000
# 3. Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google 登录:
# 1. 访问 https://console.cloud.google.com/ 并创建项目。
# 2. 在 [凭据] 页面创建 "OAuth 客户端 ID"，应用类型选择 "Web 应用"。
# 3. 已获授权的重定向 URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ================================
# 邮件服务器配置 (SMTP)
# ================================
# 用于发送注册验证、找回密码等邮件。环境变量配置后，管理后台配置将失效。

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Token 过期时间（秒）
JWT_EXPIRES_IN=86400

# ================================
# 上传配置
# ================================

# 上传目录
UPLOAD_DIR=./public/uploads

# 最大文件大小（字节）
MAX_FILE_SIZE=10485760
